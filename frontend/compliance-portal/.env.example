# Public frontend configuration. Never place client secrets in VITE_* variables.
VITE_API_BASE_URL=/api/v1
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_SCOPES=api://00000000-0000-0000-0000-000000000000/access_as_user

# Explicitly bypasses frontend sign-in for UI-only local review. The backend
# remains authenticated and API calls will fail without a valid bearer token.
VITE_DEMO_MODE=false
