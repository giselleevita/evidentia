FROM gradle:8.5-jdk17 AS build
WORKDIR /app
COPY backend/common ./backend/common
COPY backend/audit-log-service ./backend/audit-log-service
COPY settings.gradle.kts build.gradle.kts ./
RUN gradle :backend:audit-log-service:build -x test --no-daemon

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/backend/audit-log-service/build/libs/*.jar app.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "app.jar"]
