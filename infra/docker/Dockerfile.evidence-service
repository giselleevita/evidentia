FROM gradle:8.5-jdk17 AS build
WORKDIR /app
COPY backend/common ./backend/common
COPY backend/evidence-service ./backend/evidence-service
COPY settings.gradle.kts build.gradle.kts ./
RUN gradle :backend:evidence-service:build -x test --no-daemon

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/backend/evidence-service/build/libs/*.jar app.jar
RUN addgroup -S app && adduser -S app -G app
USER app
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
