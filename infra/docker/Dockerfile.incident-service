FROM gradle:8.5-jdk17 AS build
WORKDIR /app
COPY backend/common ./backend/common
COPY backend/incident-service ./backend/incident-service
COPY settings.gradle.kts build.gradle.kts ./
RUN gradle :backend:incident-service:build -x test --no-daemon

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/backend/incident-service/build/libs/*.jar app.jar
EXPOSE 8083
ENTRYPOINT ["java", "-jar", "app.jar"]
